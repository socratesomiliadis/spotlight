# Convex
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud
NEXT_PUBLIC_CONVEX_SITE_URL=https://your-deployment.convex.site

# Better Auth
# Generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=replace_with_64_hex_chars

# Local development auth origin. Set production deployments to your real app URL.
SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001

# Email delivery for Better Auth verification, OTP, reset, and claim flows
RESEND_API_KEY=re_xxxxxxxxx
AUTH_EMAIL_FROM=Spotlight <auth@example.com>

# Stripe
STRIPE_SECRET_KEY=sk_test_xxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxx
CONVEX_STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxx
NEXT_PUBLIC_STRIPE_PRICE_ID=price_xxxxxxxxx

# Optional integrations
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Migration-only values. Remove or rotate after migration.
CONVEX_MIGRATION_SECRET=replace_with_64_hex_chars
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SECRET_KEY=your_supabase_service_role_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Legacy Clerk values are only needed while exporting/importing users.
CLERK_SECRET_KEY=sk_live_or_test_xxxxxxxxx
